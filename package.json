{
  "name": "office-requests",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "pnpm --filter @office/shared build",
    "dev": "pnpm build:shared && concurrently -n shared,api,web -c gray,cyan,magenta \"pnpm --filter @office/shared dev\" \"pnpm --filter @office/api dev\" \"pnpm --filter @office/web dev\"",
    "build": "pnpm build:shared && pnpm --filter @office/api build && pnpm --filter @office/web build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @office/api db:migrate",
    "db:generate": "pnpm --filter @office/api db:generate",
    "test:shared": "pnpm --filter @office/shared test",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
