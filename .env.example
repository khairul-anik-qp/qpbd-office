# ─── Auth ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
BOOTSTRAP_ADMIN_EMAILS=admin@gmail.com

# ─── DB ──────────────────────────────────────────────────────────────────
# Dev: localhost via `pnpm db:up`. Prod docker-compose sets DATABASE_URL for the api service.
DATABASE_URL=postgresql://office:office@localhost:5432/office_requests
POSTGRES_USER=office
POSTGRES_PASSWORD=office
POSTGRES_DB=office_requests
# Host port for dev postgres only (`docker compose up postgres`)
POSTGRES_PORT=5432

# ─── Push (Web Push / FCM) ───────────────────────────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
# Optional: GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json
FCM_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# web-push subject must be https: or mailto: (APP_URL http://localhost is auto-fallback)
# VAPID_SUBJECT=mailto:you@example.com
# Exposed to Vite for staff push subscription
VITE_VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY}

# ─── Reminders ─────────────────────────────────────────────────────────────
STAFF_REMINDER_INTERVAL_MINUTES=5
STAFF_REMINDER_ENABLED=true

# ─── App ─────────────────────────────────────────────────────────────────
# Public URL (HTTPS in production — required for PWA install + push)
APP_URL=http://localhost:5173
APP_DOMAIN=
API_PORT=3000
NODE_ENV=development
HTTP_PORT=80
HTTPS_PORT=443
# Same value as GOOGLE_CLIENT_ID — exposed to Vite for Google Sign-In button
VITE_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}

# ─── Email (optional) ──────────────────────────────────────────────────────
RESEND_API_KEY=
# Sender address. Use onboarding@resend.dev for testing before your domain is verified.
RESEND_FROM=Office Requests <onboarding@resend.dev>
