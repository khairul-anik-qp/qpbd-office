# ─── Auth ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
BOOTSTRAP_ADMIN_EMAILS=admin@gmail.com

# ─── DB ──────────────────────────────────────────────────────────────────
# Matches docker-compose postgres service defaults below
# If POSTGRES_PORT is not 5432, update the port here (e.g. localhost:5433)
DATABASE_URL=postgresql://office:office@localhost:5432/office_requests
POSTGRES_USER=office
POSTGRES_PASSWORD=office
POSTGRES_DB=office_requests
# Host port for the docker postgres. Change if 5432 is taken by a local install.
POSTGRES_PORT=5432

# ─── Push ────────────────────────────────────────────────────────────────
FCM_PROJECT_ID=
FCM_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Reminders ─────────────────────────────────────────────────────────────
STAFF_REMINDER_INTERVAL_MINUTES=5
STAFF_REMINDER_ENABLED=true

# ─── App ─────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
API_PORT=3000
NODE_ENV=development
# Same value as GOOGLE_CLIENT_ID — exposed to Vite for Google Sign-In button
VITE_GOOGLE_CLIENT_ID=

# ─── Email (optional) ──────────────────────────────────────────────────────
RESEND_API_KEY=
