generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  staff
  admin
}

enum UserStatus {
  pending
  active
  rejected
}

enum Availability {
  available
  busy
  away
}

model User {
  id             String        @id @default(cuid())
  googleId       String        @unique
  email          String        @unique
  nameEn         String
  nameBn         String?
  photoUrl       String?
  role           UserRole
  status         UserStatus    @default(pending)
  brandColor     String?
  availability   Availability?
  lastAcceptedAt DateTime?
  createdAt      DateTime      @default(now())
  approvedAt     DateTime?
}
