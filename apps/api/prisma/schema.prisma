generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  employee
  staff
  admin
}

enum UserStatus {
  pending
  active
  rejected
}

enum Availability {
  available
  busy
  away
}

enum RequestType {
  tea
  snack
  supply
  printer
  help
  other
}

enum Urgency {
  normal
  urgent
}

enum RequestStatus {
  new
  progress
  done
}

model User {
  id             String        @id @default(cuid())
  googleId       String        @unique
  email          String        @unique
  nameEn         String
  nameBn         String?
  photoUrl       String?
  role           UserRole
  status         UserStatus    @default(pending)
  brandColor     String?
  availability          Availability?
  availabilityChangedAt DateTime?
  lastAcceptedAt        DateTime?
  createdAt      DateTime      @default(now())
  approvedAt     DateTime?

  requestsCreated  Request[] @relation("RequestRequester")
  requestsAssigned Request[] @relation("RequestAssignee")
  requestsForwarded Request[] @relation("RequestForwardedBy")
  requestsAccepted Request[] @relation("RequestAcceptedBy")
  requestsDone     Request[] @relation("RequestDoneBy")
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model Request {
  id            String        @id @default(cuid())
  type          RequestType
  requester     String
  requesterId   String
  note          String        @default("")
  urg           Urgency       @default(normal)
  loc           String
  assigneeId    String?
  status        RequestStatus @default(new)
  forwardedById String?
  acceptedById  String?
  acceptedAt    DateTime?
  doneById      String?
  doneAt        DateTime?
  createdAt     DateTime      @default(now())

  requesterUser User  @relation("RequestRequester", fields: [requesterId], references: [id])
  assignee      User? @relation("RequestAssignee", fields: [assigneeId], references: [id])
  forwardedBy   User? @relation("RequestForwardedBy", fields: [forwardedById], references: [id])
  acceptedBy    User? @relation("RequestAcceptedBy", fields: [acceptedById], references: [id])
  doneBy        User? @relation("RequestDoneBy", fields: [doneById], references: [id])

  @@index([requesterId])
  @@index([status])
  @@index([assigneeId])
  @@index([acceptedById])
  @@index([doneById])
}
